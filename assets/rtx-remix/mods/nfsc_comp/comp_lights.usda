                asset inputs:diffuse_texture = @./assets/world/lamps/147A3BB67DAC29FE_albedo.a.rtex.dds@
                custom float inputs:emissive_intensity = 18
                custom asset inputs:emissive_mask_texture = @./assets/world/lamps/147A3BB67DAC29FE_emissive.e.rtex.dds@
